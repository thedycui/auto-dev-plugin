# Root level
node_modules/
dist/
*.js
*.d.ts
*.js.map
*.d.ts.map
!.eslintrc.js
!mcp/src/**

# MCP server - include dist/ and node_modules/ for zero-build install
!mcp/dist/
!mcp/dist/**/*.js
!mcp/dist/**/*.js.map
!mcp/node_modules/

# IDE / editor
.idea/

# Build artifacts
*.tgz
*.bak

# Auto-dev run artifacts (regenerable)
docs/auto-dev/*/*.patch
docs/auto-dev/*/framework-test-*.txt

# Backup directories
docs/auto-dev/*.bak.*/
docs/auto-dev/_self-assess/

# Temporary directories
.agent-hub/
.claude/
.playwright-mcp/
mcp/node_modules/.bin/
mcp/node_modules/.vite/

